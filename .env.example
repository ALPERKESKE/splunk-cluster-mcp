# Splunk Cluster MCP — environment config
# Copy to .env and fill in real values. .env is gitignored.

# Cluster Manager URL — discovers indexer peers + license manager URI
SPLUNK_BOOTSTRAP_URL=https://cm.example.com:8089

# Any SHC member URL — used to discover SHC members + captain
# Optional. If unset, search-head discovery is skipped.
SPLUNK_SHC_BOOTSTRAP_URL=https://sh.example.com:8089

# --- Auth: token preferred, basic auth as fallback -----------------

# Bearer token (recommended). Create one in Splunk:
#   Web UI: Settings → Tokens → New Token
#   REST:   POST /services/authorization/tokens
# Tokens can be scoped per-role and revoked individually.
SPLUNK_TOKEN=

# OR (fallback) HTTP basic auth — uses your admin password.
# Only one auth mode is used at a time; if TOKEN is set, USERNAME and
# PASSWORD are ignored.
SPLUNK_USERNAME=admin
SPLUNK_PASSWORD=CHANGE_ME

# --- TLS -----------------------------------------------------------

# Verify the Splunk TLS certificate. Default true (secure).
# Set to "false" ONLY for lab/dev with self-signed certs.
SPLUNK_VERIFY_SSL=true

# --- Tuning --------------------------------------------------------

# Topology cache TTL in seconds (how often to re-discover peers etc.)
TOPOLOGY_CACHE_TTL=60

# Default search time range (relative)
SEARCH_DEFAULT_EARLIEST=-15m
SEARCH_DEFAULT_LATEST=now

# Log level for the gateway itself
LOG_LEVEL=INFO
